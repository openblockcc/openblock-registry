{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://registry.openblock.cc/schemas/registry.schema.json",
    "title": "OpenBlock Registry",
    "description": "Schema for OpenBlock Registry registry.json - contains repository URLs for devices and extensions",
    "type": "object",
    "required": ["devices", "extensions"],
    "properties": {
        "devices": {
            "type": "array",
            "description": "List of device repository URLs",
            "items": {
                "type": "string",
                "format": "uri",
                "pattern": "^https://github\\.com/[^/]+/[^/]+$",
                "description": "GitHub repository URL for a device package"
            },
            "uniqueItems": true
        },
        "extensions": {
            "type": "array",
            "description": "List of extension repository URLs",
            "items": {
                "type": "string",
                "format": "uri",
                "pattern": "^https://github\\.com/[^/]+/[^/]+$",
                "description": "GitHub repository URL for an extension package"
            },
            "uniqueItems": true
        },
        "recommended": {
            "type": "object",
            "description": "Maintainer-owned opt-in allowlist of packages shown in the front of the library. Each URL must also appear in the matching devices/extensions list (enforced by the validator).",
            "properties": {
                "devices": {
                    "type": "array",
                    "description": "Recommended device repository URLs",
                    "items": {
                        "type": "string",
                        "format": "uri",
                        "pattern": "^https://github\\.com/[^/]+/[^/]+$"
                    },
                    "uniqueItems": true
                },
                "extensions": {
                    "type": "array",
                    "description": "Recommended extension repository URLs",
                    "items": {
                        "type": "string",
                        "format": "uri",
                        "pattern": "^https://github\\.com/[^/]+/[^/]+$"
                    },
                    "uniqueItems": true
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}

